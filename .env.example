# --- Discord ---
# Bot token from https://discord.com/developers/applications -> Bot -> Reset Token
DISCORD_TOKEN=
# Application (Client) ID from the same dashboard, General Information page
DISCORD_CLIENT_ID=
# Channel where tilt notifications are posted. Enable Developer Mode in Discord
# (Settings -> Advanced) then right-click the channel -> Copy Channel ID.
DISCORD_CHANNEL_ID=
# Optional: scope slash commands to a single guild for instant updates during dev.
# Leave blank to register globally (propagation can take up to ~1 hour).
DISCORD_GUILD_ID=

# --- Riot Games API ---
# Dev key rotates every 24h. Get one at https://developer.riotgames.com/
RIOT_API_KEY=
# Regional routing for account-v1 + match-v5:
#   americas -> NA, BR, LAN, LAS, OCE
#   europe   -> EUW, EUNE, RU, TR
#   asia     -> KR, JP
#   sea      -> SEA / VN / TH / PH / SG
RIOT_REGIONAL_ROUTING=americas

# Platform routing for league-v4 (ranked/LP queries). Unlike regional routing,
# this is a SPECIFIC server shard. Use whichever your tracked players are on:
#   na1 (NA) | br1 | la1 (LAN) | la2 (LAS) | oc1 (OCE)
#   euw1 | eun1 | tr1 | ru
#   kr | jp1
#   ph2 | sg2 | th2 | tw2 | vn2
RIOT_PLATFORM_ROUTING=na1

# --- Polling ---
# How often to poll Riot for new matches, in milliseconds.
# 60000 (1 minute) is a safe default that keeps us well under dev-key rate limits.
POLL_INTERVAL_MS=60000
